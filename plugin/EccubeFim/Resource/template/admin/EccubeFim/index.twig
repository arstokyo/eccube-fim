{% extends '@admin/default_frame.twig' %}

{% block title %}{{ 'eccube_fim.title'|trans }}{% endblock %}
{% block sub_title %}{{ 'eccube_fim.title'|trans }}{% endblock %}

{% block main %}
<div class="c-contentsArea__cols">
    <div class="c-contentsArea__primaryCol">

        {% if not status.available %}
        {# ── エラー表示 ────────────────────────────────────────── #}
        <div class="alert alert-danger" role="alert">
            <i class="fa fa-exclamation-triangle mr-1"></i>
            {{ status.error|trans }}
        </div>
        <p class="text-muted">
            {{ 'eccube_fim.hint.reinstall'|trans|raw }}<br>
            {{ 'eccube_fim.hint.check_status'|trans|raw }}
        </p>

        {% else %}

        {# ── ステータスが古い場合の警告 ───────────────────────── #}
        {% if status.status_stale %}
        <div class="alert alert-warning" role="alert">
            <i class="fa fa-clock mr-1"></i>
            {{ 'eccube_fim.warning.stale'|trans({'%age%': status.generated_age_fmt}) }}
        </div>
        {% endif %}

        {# ── サービス状態パネル ───────────────────────────────── #}
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa fa-shield-alt mr-1"></i> {{ 'eccube_fim.panel.service_status'|trans }}</span>
                <small class="text-muted">
                    {{ status.generated_at_fmt ?? '' }} {{ 'eccube_fim.label.updated'|trans }}
                    （{{ status.generated_age_fmt ?? '' }}）
                </small>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-4 mb-3">
                        <div class="text-muted small mb-1">{{ 'eccube_fim.label.heartbeat'|trans }}</div>
                        {% if status.heartbeat.enabled %}
                            {% if status.heartbeat.health == 'OK' %}
                                <span class="badge badge-success badge-pill">OK</span>
                            {% elseif status.heartbeat.health == 'STALE' %}
                                <span class="badge badge-warning badge-pill">STALE</span>
                            {% else %}
                                <span class="badge badge-danger badge-pill">NOT FOUND</span>
                            {% endif %}
                            <br>
                            <small class="text-muted">
                                {{ status.heartbeat.last_seen_fmt ?? '' }}
                            </small>
                        {% else %}
                            <span class="badge badge-secondary badge-pill">{{ 'eccube_fim.label.disabled'|trans }}</span>
                        {% endif %}
                    </div>
                    <div class="col-sm-4 mb-3">
                        <div class="text-muted small mb-1">{{ 'eccube_fim.label.suppressed_files'|trans }}</div>
                        {% if status.suppressed_count > 0 %}
                            <span class="badge badge-warning badge-pill">
                                {{ status.suppressed_count }} {{ 'eccube_fim.label.count_unit'|trans }}
                            </span>
                        {% else %}
                            <span class="badge badge-secondary badge-pill">0 {{ 'eccube_fim.label.count_unit'|trans }}</span>
                        {% endif %}
                    </div>
                    <div class="col-sm-4 mb-3">
                        <div class="text-muted small mb-1">{{ 'eccube_fim.label.version_host'|trans }}</div>
                        <small>
                            v{{ status.daemon_version ?? 'N/A' }}<br>
                            {{ status.hostname ?? '' }}
                        </small>
                    </div>
                </div>
            </div>
        </div>

        {# ── 最近の検知一覧 ────────────────────────────────────── #}
        <div class="card mb-4">
            <div class="card-header">
                <i class="fa fa-exclamation-circle mr-1"></i>
                {{ 'eccube_fim.panel.recent_detections'|trans }}
            </div>
            {% if status.recent_detections is empty %}
            <div class="card-body text-muted">
                <i class="fa fa-check-circle text-success mr-1"></i> {{ 'eccube_fim.label.no_detections'|trans }}
            </div>
            {% else %}
            <div class="card-body p-0">
                <table class="table table-sm table-bordered table-hover mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>{{ 'eccube_fim.table.file_path'|trans }}</th>
                            <th style="width: 180px">{{ 'eccube_fim.table.last_detected'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for det in status.recent_detections %}
                        <tr>
                            <td><code class="text-danger">{{ det.file_path }}</code></td>
                            <td>{{ det.detected_at_fmt ?? '-' }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}
        </div>

        {# ── 最近のログ ────────────────────────────────────────── #}
        <div class="card mb-4">
            <div class="card-header">
                <i class="fa fa-list-alt mr-1"></i>
                {{ 'eccube_fim.panel.recent_log'|trans }}
            </div>
            <div class="card-body p-0">
                {% if status.recent_log is empty %}
                <div class="p-3 text-muted">{{ 'eccube_fim.label.no_log'|trans }}</div>
                {% else %}
                <pre class="m-0 p-3"
                     style="font-size: 0.78rem; max-height: 400px; overflow-y: auto;
                            background: #1e1e1e; color: #d4d4d4; border-radius: 0;">{{ status.recent_log|join("\n") }}</pre>
                {% endif %}
            </div>
        </div>

        {% endif %}{# end status.available #}

        {# ══════════════════════════════════════════════════════════
           マルウェアスキャンセクション
           ══════════════════════════════════════════════════════════ #}

        {% if not malware_status.installed %}
        <div class="alert alert-secondary" role="alert">
            <i class="fa fa-info-circle mr-1"></i>
            {{ 'eccube_fim.malware.label.not_installed'|trans }}
            <br>
            <small class="text-muted">{{ 'eccube_fim.malware.label.not_installed_hint'|trans|raw }}</small>
        </div>

        {% elseif not malware_status.available %}
        <div class="alert alert-danger" role="alert">
            <i class="fa fa-exclamation-triangle mr-1"></i>
            {{ malware_status.error|trans }}
        </div>

        {% else %}

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa fa-bug mr-1"></i> {{ 'eccube_fim.malware.panel.service_status'|trans }}</span>
                <small class="text-muted">
                    {{ malware_status.generated_at_fmt ?? '' }} {{ 'eccube_fim.label.updated'|trans }}
                    （{{ malware_status.generated_age_fmt ?? '' }}）
                </small>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-3 mb-3">
                        <div class="text-muted small mb-1">{{ 'eccube_fim.malware.label.last_scan'|trans }}</div>
                        {% if malware_status.last_scan_at is not null %}
                            <small>{{ malware_status.last_scan_at_fmt }}</small>
                        {% else %}
                            <span class="text-muted small">—</span>
                        {% endif %}
                    </div>
                    <div class="col-sm-3 mb-3">
                        <div class="text-muted small mb-1">{{ 'eccube_fim.malware.label.scan_result'|trans }}</div>
                        {% set ss = malware_status.last_scan_status %}
                        {% if ss == 'clean' %}
                            <span class="badge badge-success badge-pill">{{ 'eccube_fim.malware.status.clean'|trans }}</span>
                        {% elseif ss == 'infected' %}
                            <span class="badge badge-danger badge-pill">
                                {{ 'eccube_fim.malware.status.infected'|trans }}（{{ malware_status.last_scan_infected_count }}件）
                            </span>
                        {% elseif ss == 'error' %}
                            <span class="badge badge-warning badge-pill">{{ 'eccube_fim.malware.status.error'|trans }}</span>
                        {% else %}
                            <span class="badge badge-secondary badge-pill">{{ 'eccube_fim.malware.status.never'|trans }}</span>
                        {% endif %}
                    </div>
                    <div class="col-sm-3 mb-3">
                        <div class="text-muted small mb-1">{{ 'eccube_fim.malware.label.suppressed'|trans }}</div>
                        {% if malware_status.suppressed_count > 0 %}
                            <span class="badge badge-warning badge-pill">{{ malware_status.suppressed_count }} {{ 'eccube_fim.label.count_unit'|trans }}</span>
                        {% else %}
                            <span class="badge badge-secondary badge-pill">0 {{ 'eccube_fim.label.count_unit'|trans }}</span>
                        {% endif %}
                    </div>
                    <div class="col-sm-3 mb-3">
                        <div class="text-muted small mb-1">{{ 'eccube_fim.malware.label.clamav'|trans }}</div>
                        <small>{{ malware_status.clamav_version ?? 'N/A' }}</small><br>
                        <small>
                            {{ 'eccube_fim.malware.label.scan_timer'|trans }}:
                            {% if malware_status.scan_timer_active %}
                                <span class="text-success">{{ 'eccube_fim.malware.label.active'|trans }}</span>
                            {% else %}
                                <span class="text-danger">{{ 'eccube_fim.malware.label.inactive'|trans }}</span>
                            {% endif %}
                            /
                            {{ 'eccube_fim.malware.label.freshclam_timer'|trans }}:
                            {% if malware_status.freshclam_timer_active %}
                                <span class="text-success">{{ 'eccube_fim.malware.label.active'|trans }}</span>
                            {% else %}
                                <span class="text-danger">{{ 'eccube_fim.malware.label.inactive'|trans }}</span>
                            {% endif %}
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <i class="fa fa-bug mr-1"></i>
                {{ 'eccube_fim.malware.panel.recent_detections'|trans }}
            </div>
            {% if malware_status.recent_detections is empty %}
            <div class="card-body text-muted">
                <i class="fa fa-check-circle text-success mr-1"></i>
                {{ 'eccube_fim.malware.label.no_detections'|trans }}
            </div>
            {% else %}
            <div class="card-body p-0">
                <table class="table table-sm table-bordered table-hover mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>{{ 'eccube_fim.malware.table.file_path'|trans }}</th>
                            <th style="width:220px">{{ 'eccube_fim.malware.table.virus_name'|trans }}</th>
                            <th style="width:180px">{{ 'eccube_fim.malware.table.detected_at'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for det in malware_status.recent_detections %}
                        <tr>
                            <td><code class="text-danger">{{ det.path }}</code></td>
                            <td><code>{{ det.virus_name }}</code></td>
                            <td>{{ det.detected_at_fmt ?? '-' }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}
        </div>

        {% endif %}{# end malware_status.installed #}

    </div>
</div>
{% endblock %}
