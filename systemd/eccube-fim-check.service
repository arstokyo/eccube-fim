[Unit]
Description=EC-CUBE File Integrity Monitoring Check
Documentation=https://github.com/arstokyo/eccube-fim
RequiresMountsFor=%%ECCUBE_ROOT%%

[Service]
Type=oneshot
ExecStart=%%SBIN_DIR%%/eccube-fim check
User=root
Group=root
StandardOutput=journal
StandardError=journal
SyslogIdentifier=eccube-fim

ProtectSystem=strict
ReadOnlyPaths=%%ECCUBE_ROOT%%
ReadWritePaths=%%LOG_DIR%% %%RUN_DIR%% %%CONFIG_DIR%%
NoNewPrivileges=true
ProtectHome=true
ProtectKernelModules=true
ProtectKernelTunables=true
PrivateTmp=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
MemoryMax=256M
CPUQuota=50%
TimeoutStartSec=120
# No [Install] — activated only by the timer, never enabled directly
